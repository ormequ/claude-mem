#!/usr/bin/env bash
# adopt-mem [worktree-dir] [--all] [--dry-run] [--orphans [--repo <path>] [--reset-declined]]
#
# Consolidates a git worktree's claude-mem observations into the parent project
# via the installed claude-mem fork (ormequ). Safe to call on worktree deletion.
# Idempotent: re-running only adopts newly-created observations (no dups).
#
#   adopt-mem                 adopt the current worktree's branch
#   adopt-mem <dir>           adopt the branch checked out in <dir>
#   adopt-mem --all           everything this repo has to adopt: scan EVERY live
#                             worktree and adopt all merged branches (regular +
#                             squash-merged), THEN review orphans (below) and
#                             prompt for each. This is the everyday command.
#   adopt-mem --dry-run       report what would be adopted, change nothing
#   adopt-mem --orphans       the orphan review alone, without the worktree scan:
#                             memory left by worktrees that were DELETED before
#                             being adopted. They are invisible to the scan above
#                             because a deleted worktree is not in
#                             `git worktree list`, so nothing else can ever see
#                             them. Adopts only after per-item approval.
#   adopt-mem --orphans --repo <path>
#                             also resolve orphan parents against <path>, in
#                             addition to the known-cwds registry
#   adopt-mem --orphans --reset-declined
#                             clear all recorded declines so every previously
#                             declined orphan is asked about again
#
# Canonical copy lives in the claude-mem repo (scripts/adopt-mem). The
# ~/.local/bin/adopt-mem entry is a symlink to this file so orca (and any
# non-zsh caller) can still run it on worktree deletion.
set -euo pipefail

# --orphans is a different job from the adoption below: it reviews memory left
# behind by worktrees that no longer exist, which the worktree-list-driven
# adoption can never see. It runs from the dev checkout (it imports src/).
# Detected anywhere in the argument list, not just $1 — `--dry-run --orphans`
# must route here too, not fall through and get read as a worktree dir.
orphans_args=()
found_orphans=""
for arg in "$@"; do
  if [[ "$arg" == "--orphans" ]]; then
    found_orphans=1
  else
    orphans_args+=("$arg")
  fi
done
if [[ -n "$found_orphans" ]]; then
  # `${arr[@]+"${arr[@]}"}` rather than a bare `"${orphans_args[@]}"`: macOS ships
  # bash 3.2, where expanding an EMPTY array under `set -u` is an unbound-variable
  # error (fixed in 4.4+). A bare `adopt-mem --orphans` leaves the array empty, so
  # the plain form breaks the most common invocation — and it breaks it precisely
  # in the contexts the ~/.local/bin symlink exists for (orca, launchd, a minimal
  # PATH), where `env bash` resolves to /bin/bash rather than a homebrew build.
  exec bun "$HOME/Development/tools/claude-mem/scripts/adopt-orphans.ts" ${orphans_args[@]+"${orphans_args[@]}"}
fi

dir="" dryrun="" all=""
for arg in "$@"; do
  case "$arg" in
    --dry-run) dryrun=1 ;;
    --all) all=1 ;;
    *) dir="$arg" ;;
  esac
done

dir="$(git -C "${dir:-$PWD}" rev-parse --show-toplevel 2>/dev/null)" || {
  echo "adopt-mem: not a git worktree: ${dir:-$PWD}" >&2
  exit 1
}

# --all: scan every worktree of the repo and adopt all merged (incl. squashed)
# branches. Otherwise adopt just the current worktree's branch (deletion hook).
branch=""
if [[ -z "$all" ]]; then
  branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)"
  if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
    echo "adopt-mem: detached/unknown branch in $dir (use --all to scan every worktree)" >&2
    exit 1
  fi
fi

# Newest ormequ plugin-cache build, falling back to the dev checkout.
shopt -s nullglob
builds=("$HOME/.claude/plugins/cache/ormequ/claude-mem"/*/scripts/worker-service.cjs)
shopt -u nullglob
ws=""
if ((${#builds[@]})); then
  ws="$(ls -t "${builds[@]}" | head -n1)"
fi
ws="${ws:-$HOME/Development/tools/claude-mem/plugin/scripts/worker-service.cjs}"

if [[ ! -f "$ws" ]]; then
  echo "adopt-mem: claude-mem fork worker script not found (ormequ cache / dev checkout)" >&2
  exit 1
fi

if [[ -n "$all" ]]; then
  # `--all` means everything this repo has to adopt, and memory left behind by
  # DELETED worktrees is part of that — the worktree-list-driven pass below can
  # never see it, because a deleted worktree is absent from `git worktree list`.
  # So run the normal pass first (its summary prints), then hand over to the
  # orphan review, which inherits this TTY and prompts per orphan.
  # Not `exec` on the first one: we need to come back for the second.
  bun "$ws" adopt --cwd "$dir" ${dryrun:+--dry-run}
  echo
  exec bun "$HOME/Development/tools/claude-mem/scripts/adopt-orphans.ts" \
    --repo "$dir" ${dryrun:+--dry-run}
fi

exec bun "$ws" adopt --cwd "$dir" ${branch:+--branch "$branch"} ${dryrun:+--dry-run}
